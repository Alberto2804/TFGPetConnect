<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/color_superficie_tarjeta"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivIconoMedico"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_help"
        app:tint="@color/colorPrimary" /> <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvFechaRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12/12/2023"
        android:textColor="@color/color_texto_secundario" android:textSize="12sp" />

    <TextView
        android:id="@+id/tvTipoRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="VACUNA"
        android:textColor="@color/colorPrimary" android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDescripcionRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Vacuna de la rabia anual"
        android:textColor="@color/color_texto_principal" android:textSize="16sp" />

</LinearLayout>

    <ImageView
        android:id="@+id/btnBorrarRegistro"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/color_error" /> </LinearLayout>
</androidx.cardview.widget.CardView>